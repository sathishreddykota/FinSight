{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "memory": 3008,
      "runtime": "python3.11"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/.next/($1)"
    }
  ]
}
